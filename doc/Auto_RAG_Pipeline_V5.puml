PromoteIndexVersionUseCase *-- EventBusPort
PromoteIndexVersionUseCase ..> PromoteIndexVersionCommand
PromoteIndexVersionUseCase ..> EvaluationPolicy

' ── Pipes & Filters composition ─────────────────────────────────────
FilterPipeline o-- PipelineFilter : "chains"
ChunkerFilter *-- ChunkerPort
EmbedderFilter *-- EmbedderPort
VectorStoreFilter *-- VectorStorePort

' ── Adapters implement Ports ────────────────────────────────────────
LocalFileSystemScraper *-- FileExtractorRegistry
LocalFileSystemScraper *-- TextPreprocessor
LocalFileSystemScraper ..> DocumentRepositoryPort : "checks hash"
FileExtractorRegistry o-- FileExtractor : "routes extension"
PreprocessorPipeline o-- TextPreprocessor : "chains steps"
ExtensionCrawlFilter ..> FileExtractorRegistry

OpenAIEmbedderAdapter *-- OpenAIEmbedderACL
PineconeVectorStoreAdapter *-- PineconeACL
PineconeRetrieverAdapter *-- PineconeACL
CohereReRankerAdapter o-- RetrieverPort : "wraps inner"
CohereReRankerAdapter *-- CohereReRankerACL
RagasEvaluatorAdapter *-- RagasACL

' ── Domain object relationships ─────────────────────────────────────
SourceDocument *-- Chunk : "owns"
SourceDocument *-- DocumentId
SourceDocument ..> IngestionStatus
Chunk *-- Provenance
Chunk *-- ChunkId
VectorPayload *-- Provenance
VectorPayload *-- ChunkId
RetrievalResult *-- Provenance
RetrievalResult *-- ChunkId
EvaluationDataset *-- EvaluationCase
EvaluationPolicy ..> EvaluationMetrics : "evaluates"

' ── Domain Events published per stage ───────────────────────────────
DocumentScraped ..> SourceDocument
DocumentChunked ..> Chunk
ChunksEmbedded ..> VectorPayload
DocumentIngested ..> DocumentId
DocumentMarkedStale ..> ChunkId
